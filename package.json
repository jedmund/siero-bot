  "license": "MIT",
  "dependencies": {
    "@sapphire/decorators": "^6.2.0",
    "@sapphire/discord.js-utilities": "^7.3.3",
    "@sapphire/framework": "^5.5.0",
    "@sapphire/plugin-subcommands": "^7.0.1",
    "@types/node": "^22.13.13",
    "chance": "^1.1.12",
    "discord.js": "^14.26.0",
    "dotenv": "^16.4.1",
    "kysely": "^0.27.2",
    "pg": "^8.11.3",
    "pluralize": "^8.0.0",
    "typescript": "^5.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/chance": "^1.1.6",
    "@types/pg": "^8.11.11",
    "@types/pluralize": "^0.0.33",
